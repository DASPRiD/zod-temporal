{
    "compilerOptions": {
        "lib": ["es6", "dom", "esnext.temporal"],
        "target": "ES2020",
        "module": "nodenext",
        "moduleResolution": "node16",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true,
        "rootDir": "src",
        "outDir": "dist"
    },
    "include": [
        "src/**/*"
    ]
}
